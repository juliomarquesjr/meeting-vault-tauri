{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Meeting Vault",
  "version": "0.1.0",
  "identifier": "com.julio.meetingvault",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Meeting Vault",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 720,
        "resizable": true,
        "decorations": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"]
  }
}
